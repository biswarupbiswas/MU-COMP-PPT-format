% Custom hyperlinked citation command
\DeclareCiteCommand{\mucomp@hyper@fullcite}
  {\defcounter{maxnames}{2}\usebibmacro{prenote}}
  {%
    \iffieldundef{doi}{%
      \iffieldundef{url}{%
        \usedriver{\DeclareNameAlias{sortname}{default}}{\thefield{entrytype}}%
      }{%
        \href{\strfield{url}}{\usedriver{\DeclareNameAlias{sortname}{default}}{\thefield{entrytype}}}%
      }%
    }{%
      \href{https://doi.org/\strfield{doi}}{\usedriver{\DeclareNameAlias{sortname}{default}}{\thefield{entrytype}}}%
    }%
  }
  {\multicitedelim}
  {\usebibmacro{postnote}}

\DeclareCiteCommand{\footfullcite}[\mkbibfootnote]
  {\defcounter{maxnames}{2}\usebibmacro{prenote}}
  {\usedriver{\DeclareNameAlias{sortname}{default}}{\thefield{entrytype}}}
  {\multicitedelim}
  {\usebibmacro{postnote}}

\DeclareCiteCommand{\footfullcitetext}[\mkbibfootnotetext]
  {\defcounter{maxnames}{2}\usebibmacro{prenote}}
  {\usedriver{\DeclareNameAlias{sortname}{default}}{\thefield{entrytype}}}
  {\multicitedelim}
  {\usebibmacro{postnote}}
\makeatother

% Reset footnote counter at every frame → marks always start at 1
\AtBeginEnvironment{frame}{\setcounter{footnote}{0}}

% \fcite{k1,k2,...} — prints superscript then places each footnotetext (with deduplication)
\newcounter{bb@fnstart}
\makeatletter
\newcommand{\fcite}[1]{%
  \def\bb@markstr{}%
  \def\bb@sep{}%
  \@for\bb@k:=#1\do{%
    \expandafter\ifx\csname mucomp@fn@\insertframenumber @\bb@k\endcsname\relax
      % First time cited on this frame
      \stepcounter{footnote}%
      \expandafter\edef\csname mucomp@fn@\insertframenumber @\bb@k\endcsname{\thefootnote}%
      \edef\bb@markstr{\bb@markstr\bb@sep\thefootnote}%
      \footnotetext[\value{footnote}]{\defcounter{maxnames}{2}\mucomp@hyper@fullcite{\bb@k}}%
    \else
      % Already cited on this frame, reuse footnote number
      \edef\bb@tempfn{\csname mucomp@fn@\insertframenumber @\bb@k\endcsname}%
      \edef\bb@markstr{\bb@markstr\bb@sep\bb@tempfn}%
    \fi
    \def\bb@sep{,}%
  }%
  {\color{citeteal}\textsuperscript{\bb@markstr}}%
}

% \fcitetext{k1,k2,...} — places footnote texts only (pair with \footnotemark, with hyperlinks)
\newcounter{bb@nkeys}
\newcommand{\fcitetext}[1]{%
  \setcounter{bb@fnstart}{\value{footnote}}%
  \setcounter{bb@nkeys}{0}%
  \@for\bb@k:=#1\do{\stepcounter{bb@nkeys}}%
  \addtocounter{bb@fnstart}{-\value{bb@nkeys}}%
  \setcounter{footnote}{\value{bb@fnstart}}%
  \@for\bb@k:=#1\do{%
    \stepcounter{footnote}%
    \footnotetext[\value{footnote}]{%
      \defcounter{maxnames}{2}\mucomp@hyper@fullcite{\bb@k}%
    }%
  }%
}
\makeatother

