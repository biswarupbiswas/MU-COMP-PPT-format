% ------------------------------------------------------------------------------
% Package options
% ------------------------------------------------------------------------------
\newif\ifmucomp@draftanim
\DeclareOption{draftanim}{\mucomp@draftanimtrue}
\DeclareOption{fastanim}{\mucomp@draftanimtrue}
\ProcessOptions\relax

% ------------------------------------------------------------------------------
% These booleans must be declared unconditionally, BEFORE the
% \ifmucomp@draftanim branch below, even though they are only *used* in the
% \else (full animate) branch. Reason: when \ifmucomp@draftanim is true, TeX
% has to skip over the entire \else branch token-by-token. Its conditional
% skipper only recognizes \fi/\else as matching a nested \if if that \if
% token already has the meaning of a real conditional at scan time. If
% \newif\ifpdfanim@auto (etc.) is declared *inside* the branch being skipped,
% then \ifpdfanim@auto is still an undefined control sequence when TeX scans
% over it, so it does not open a new (skipped) conditional level. The very
% next \fi then incorrectly closes the outer \ifmucomp@draftanim instead,
% causing the rest of the "fast" branch to be executed for real -- this is
% exactly what produced the "Undefined control sequence" errors on
% \ifpdfanim@loop, \ifpdfanim@palindrome, etc. and the subsequent
% "\embedanim already defined" errors.
% ------------------------------------------------------------------------------
\newif\ifpdfanim@auto
\newif\ifpdfanim@loop
\newif\ifpdfanim@palindrome
\newif\ifpdfanim@step
\newif\ifpdfanim@nomouse
\newif\ifpdfanim@draft

