% ==============================================================================
% 10. PDF ANIMATION HELPERS
% ==============================================================================
\RequirePackage{keyval}
\RequirePackage{graphicx}

%-----------------------------------------------------------------------
% pdfanim key family — declared unconditionally, BEFORE the
% \ifmucomp@draftanim branch, and used by BOTH the fast (draftanim) and
% full (animate) implementations of \pdfanim below.
%
% Previously these \define@key{pdfanim}{...} calls lived only inside the
% \else (full animate) branch. In fastanim mode that branch is skipped
% entirely, so \setkeys{pdfanim}{...} in the fast \pdfanim had no keys
% registered for the family at all -- hence the
% "Package xkeyval Error: `width' undefined in families `pdfanim'"
% errors (and similarly for autostart/loop/fps/etc.) on every \pdfanim
% call when compiling with the fastanim/draftanim option.
%-----------------------------------------------------------------------
\def\pdfanim@true{true}
\def\pdfanim@on{on}
\def\pdfanim@yes{yes}
\def\pdfanim@autoopt{auto}
\def\pdfanim@empty{}

% Accept true/on/yes as "enable"; anything else disables.
\def\pdfanim@setif#1#2#3{%
  \edef\pdfanim@tmp{#1}%
  \ifx\pdfanim@tmp\pdfanim@true #2\else
  \ifx\pdfanim@tmp\pdfanim@on   #2\else
  \ifx\pdfanim@tmp\pdfanim@yes  #2\else
  #3\fi\fi\fi}

\define@key{pdfanim}{width}{\def\pdfanim@width{#1}}
\define@key{pdfanim}{height}{\def\pdfanim@height{#1}}
\define@key{pdfanim}{scale}{\def\pdfanim@scale{#1}}
\define@key{pdfanim}{fps}{\def\pdfanim@fps{#1}}
\define@key{pdfanim}{rate}{\def\pdfanim@fps{#1}}
\define@key{pdfanim}{auto}{\pdfanim@setif{#1}{\pdfanim@autotrue}{\pdfanim@autofalse}}
\define@key{pdfanim}{autostart}{\pdfanim@setif{#1}{\pdfanim@autotrue}{\pdfanim@autofalse}}
\define@key{pdfanim}{autoplay}{\pdfanim@setif{#1}{\pdfanim@autotrue}{\pdfanim@autofalse}}
\define@key{pdfanim}{loop}{\pdfanim@setif{#1}{\pdfanim@looptrue}{\pdfanim@loopfalse}}
\define@key{pdfanim}{palindrome}{\pdfanim@setif{#1}{\pdfanim@palindrometrue}{\pdfanim@palindromefalse}}
\define@key{pdfanim}{step}{\pdfanim@setif{#1}{\pdfanim@steptrue}{\pdfanim@stepfalse}}
\define@key{pdfanim}{nomouse}{\pdfanim@setif{#1}{\pdfanim@nomousetrue}{\pdfanim@nomousefalse}}
\define@key{pdfanim}{draft}{\pdfanim@setif{#1}{\pdfanim@drafttrue}{\pdfanim@draftfalse}}
\define@key{pdfanim}{controls}{\def\pdfanim@controls{#1}}
\define@key{pdfanim}{manualcontrols}{\def\pdfanim@manualcontrols{#1}}
\define@key{pdfanim}{manual-controls}{\def\pdfanim@manualcontrols{#1}}
\define@key{pdfanim}{poster}{\def\pdfanim@poster{#1}}
\define@key{pdfanim}{method}{\def\pdfanim@method{#1}}
\define@key{pdfanim}{buttonsize}{\def\pdfanim@buttonsize{#1}}
\define@key{pdfanim}{buttonbg}{\def\pdfanim@buttonbg{#1}}
\define@key{pdfanim}{buttonfg}{\def\pdfanim@buttonfg{#1}}
\define@key{pdfanim}{buttonalpha}{\def\pdfanim@buttonalpha{#1}}
\define@key{pdfanim}{options}{\def\pdfanim@extraoptions{#1}}

%-----------------------------------------------------------------------
% Backward-compatible "okularvideo" key family.
% Generated from a single list instead of one hand-written \define@key
% per key, so old documents that used \okularvideo{...} still work.
% Also declared unconditionally for the same reason as above.
%-----------------------------------------------------------------------
\def\pdfanim@compatkeys{width,height,scale,fps,rate,auto,autostart,%
  autoplay,loop,palindrome,step,nomouse,draft,controls,manualcontrols,%
  manual-controls,poster,method,buttonsize,buttonbg,buttonfg,%
  buttonalpha,options}

\def\pdfanim@definecompat#1{%
  \define@key{okularvideo}{#1}{\setkeys{pdfanim}{#1={##1}}}}

\@for\pdfanim@k:=\pdfanim@compatkeys\do{%
  \expandafter\pdfanim@definecompat\expandafter{\pdfanim@k}}

\ifmucomp@draftanim
  % Fast build mode: show only the first frame.
  \newcommand{\pdfanim}[4][]{%
    \begingroup
    \def\pdfanim@width{\linewidth}%
    \def\pdfanim@height{}%
    \def\pdfanim@scale{}%
    \setkeys{pdfanim}{#1}%
    \def\pdfanim@opts{}%
    \edef\pdfanim@opts{\pdfanim@opts%
      \ifx\pdfanim@width\@empty\else width=\pdfanim@width\fi}%
    \ifx\pdfanim@scale\@empty\else
      \edef\pdfanim@opts{\pdfanim@opts,scale=\pdfanim@scale}%
    \fi
    \ifx\pdfanim@height\@empty\else
      \edef\pdfanim@opts{\pdfanim@opts,height=\pdfanim@height}%
    \fi
    \expandafter\includegraphics\expandafter[\pdfanim@opts]{#2#3}%
    \endgroup}
  \newcommand{\embedanim}[4][]{\pdfanim[#1]{#2}{#3}{#4}}
  \newcommand{\embedvideo}[4][]{\pdfanim[#1]{#2}{#3}{#4}}
\else
  \RequirePackage{animate}
  \RequirePackage{shellesc}

  \def\pdfanim@addoption#1{%
    \ifx\pdfanim@options\pdfanim@empty
      \def\pdfanim@options{#1}%
    \else
      \expandafter\def\expandafter\pdfanim@options\expandafter{\pdfanim@options,#1}%
    \fi}

  \def\pdfanim@addkeyval#1#2{%
    \edef\pdfanim@tmp{#2}%
    \ifx\pdfanim@tmp\pdfanim@empty\else
      \edef\pdfanim@expanded{#1=#2}%
      \expandafter\pdfanim@addoption\expandafter{\pdfanim@expanded}%
    \fi}

  \def\pdfanim@defaults{%
    \def\pdfanim@width{\linewidth}%
    \def\pdfanim@height{}%
    \def\pdfanim@scale{}%
    \def\pdfanim@fps{2}%
    \def\pdfanim@controls{auto}%
    \def\pdfanim@manualcontrols{false}%
    \def\pdfanim@poster{first}%
    \def\pdfanim@method{ocg}%
    \def\pdfanim@buttonsize{}%
    \def\pdfanim@buttonbg{}%
    \def\pdfanim@buttonfg{}%
    \def\pdfanim@buttonalpha{}%
    \def\pdfanim@extraoptions{}%
    \pdfanim@autotrue
    \pdfanim@looptrue
    \pdfanim@palindromefalse
    \pdfanim@stepfalse
    \pdfanim@nomousefalse
    \pdfanim@draftfalse}

  %-----------------------------------------------------------------------
  % Main macro
  %-----------------------------------------------------------------------
  \newcommand{\pdfanim}[4][]{%
    \begingroup
    \pdfanim@defaults
    \setkeys{pdfanim}{#1}%
    \def\pdfanim@options{}%
    \pdfanim@addkeyval{width}{\pdfanim@width}%
    \pdfanim@addkeyval{height}{\pdfanim@height}%
    \pdfanim@addkeyval{scale}{\pdfanim@scale}%
    \pdfanim@addkeyval{poster}{\pdfanim@poster}%
    \pdfanim@addkeyval{method}{\pdfanim@method}%
    \pdfanim@addkeyval{buttonsize}{\pdfanim@buttonsize}%
    \pdfanim@addkeyval{buttonbg}{\pdfanim@buttonbg}%
    \pdfanim@addkeyval{buttonfg}{\pdfanim@buttonfg}%
    \pdfanim@addkeyval{buttonalpha}{\pdfanim@buttonalpha}%
    \ifpdfanim@auto\pdfanim@addoption{autoplay}\fi
    \ifpdfanim@loop\pdfanim@addoption{loop}\fi
    \ifpdfanim@palindrome\pdfanim@addoption{palindrome}\fi
    \ifpdfanim@step\pdfanim@addoption{step}\fi
    \ifpdfanim@nomouse\pdfanim@addoption{nomouse}\fi
    \ifpdfanim@draft\pdfanim@addoption{draft}\fi
    \edef\pdfanim@tmp{\pdfanim@controls}%
    \ifx\pdfanim@tmp\pdfanim@autoopt
      \ifpdfanim@auto\else
        \pdfanim@addkeyval{controls}{\pdfanim@manualcontrols}%
      \fi
    \else
      \pdfanim@addkeyval{controls}{\pdfanim@controls}%
    \fi
    \ifx\pdfanim@extraoptions\pdfanim@empty\else
      \pdfanim@addoption{\pdfanim@extraoptions}%
    \fi
    \expandafter\animategraphics\expandafter[\pdfanim@options]{\pdfanim@fps}{#2}{#3}{#4}%
    \endgroup}

  \newcommand{\embedanim}[4][]{\pdfanim[#1]{#2}{#3}{#4}}
  \newcommand{\embedvideo}[4][]{\pdfanim[#1]{#2}{#3}{#4}}

  %-----------------------------------------------------------------------
  % Optional: shrink the compiled PDF with Ghostscript.
  %
  % animategraphics embeds every frame as a full image, so a 200-frame
  % animation embeds 200 images -- this is almost always what makes the
  % PDF huge, not anything LaTeX does. Two complementary fixes:
  %
  %  (1) Shrink frames BEFORE compiling (does the most good):
  %        - Save frames as JPEG, not PNG, unless you need transparency.
  %        - Render at the size you will actually display them, not at
  %          publication/print resolution (150 dpi is plenty for a slide).
  %        - Drop redundant frames / lower fps if the motion is simple.
  %
  %  (2) Recompress the finished PDF as a convenience pass:
  %        \pdfanimCompressPDF[ebook]   in the preamble
  %      Requires compiling with -shell-escape and Ghostscript (gs) on
  %      PATH. Writes \jobname-compressed.pdf; the original output is
  %      left untouched so you can compare sizes.
  %-----------------------------------------------------------------------
  \def\pdfanim@compresspdf#1#2{%
    \AtEndDocument{%
      \immediate\write18{gs -q -dNOPAUSE -dBATCH -dSAFER -sDEVICE=pdfwrite%
        -dCompatibilityLevel=1.5 -dPDFSETTINGS=/#1 #2%
        -sOutputFile=\jobname-compressed.pdf \jobname.pdf}%
      \typeout{^^Jpdfanim: attempted Ghostscript compression ->
        \jobname-compressed.pdf (needs -shell-escape and gs on PATH;
        \jobname.pdf itself is left untouched).^^J}}}

  % \pdfanimCompressPDF[profile]  -- profile: screen | ebook | printer | prepress
  \newcommand{\pdfanimCompressPDF}[1][ebook]{\pdfanim@compresspdf{#1}{}}

  % \pdfanimCompressPDFExtra[profile]{extra gs args}, e.g. to cap image dpi:
  %   \pdfanimCompressPDFExtra[ebook]{-dColorImageResolution=150
  %     -dGrayImageResolution=150 -dMonoImageResolution=150}
  \newcommand{\pdfanimCompressPDFExtra}[2][ebook]{\pdfanim@compresspdf{#1}{#2}}
\fi

\makeatother

\endinput