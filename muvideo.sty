\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{muvideo}[2026/07/03 Standalone native PDF video embedding from scratch]

% Check if beamer's internal pdfannot wrapper is available, otherwise default to raw pdfannot
\providecommand{\beamer@pdfannot}{\pdfannot}

% Custom macro for embedding MP4 videos via raw PDF Movie Annotations
% #1 = optional parameters (for compatibility)
% #2 = vector poster graphics or text to display under the clickable area
% #3 = MP4 video filename
\newcommand{\embedmpfour}[3][]{%
  \leavevmode
  % Embed the MP4 video stream directly into the PDF document
  \immediate\pdfobj stream file {#3}%
  \edef\videoobj{\the\pdflastobj}%
  % Set up the vector placeholder sizing
  \setbox\@tempboxa=\hbox{#2}%
  \@tempdima=\wd\@tempboxa
  \@tempdimb=\ht\@tempboxa
  \@tempdimc=\dp\@tempboxa
  % Register a page-action to automatically play the movie when the slide is opened
  \global\pdfpageattr{/AA << /O << /S /Movie /T (muvideo@#3) /Operation /Play >> >>}%
  % Create the Movie annotation with embedded stream and a matching title (/T)
  \beamer@pdfannot width \@tempdima height \@tempdimb depth \@tempdimc {
    /Subtype /Movie
    /T (muvideo@#3)
    /Border [0 0 0]
    /BS << /W 0 /S /S >>
    /F 4
    /Movie <<
      /F <<
        /Type /Filespec
        /F (#3)
        /EF << /F \videoobj\space 0 R >>
      >>
      /Aspect [1 1]
      /Poster false
    >>
    /A << >>
  }%
  % Render the underlying vector graphics card
  \box\@tempboxa
}

\endinput
